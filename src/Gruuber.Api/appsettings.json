{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=gruuber;Username=gruuber;Password=gruuber",
    "Redis": "localhost:6379"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "gruuber-tracking",
    "RideRegions": [1]
  },
  "Jwt": {
    "Issuer": "gruuber-auth",
    "Audience": "gruuber-api",
    "AccessTokenTtlMinutes": 15,
    "RefreshTokenTtlDays": 30
  },
  "ReverseProxy": {
    "Routes": {},
    "Clusters": {}
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "OpenTelemetry": {
    "Endpoint": ""
  },
  "RateLimiting": {
    "Rider": { "RequestsPerMinute": 100 },
    "Driver": { "RequestsPerMinute": 300, "LocationUpdatesPerSecond": 20 },
    "Restaurant": { "RequestsPerMinute": 200 },
    "Anonymous": { "RequestsPerMinute": 20 }
  },
  "AllowedHosts": "*"
}
